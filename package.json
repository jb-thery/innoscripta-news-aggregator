{
  "name": "innoscripta-news-aggregator",
  "version": "1.0.0",
  "homepage": "https://jb-thery.github.io/innoscripta-news-aggregator/",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "predev": "pnpm generate:api",
    "dev": "concurrently -k -n server,client -c cyan,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "prebuild": "pnpm generate:api",
    "build": "vite build && pnpm build:server",
    "build:pages": "VITE_BASE_PATH=/innoscripta-news-aggregator/ VITE_HASH_ROUTING=true pnpm build:static-demo",
    "build:static-demo": "pnpm generate:api && VITE_ENABLE_MOCK_DATA=true vite build",
    "build:server": "tsup",
    "preview": "node server-dist/index.js",
    "preview:static": "vite preview --host 0.0.0.0",
    "generate:openapi": "tsx server/openapi.ts",
    "generate:api": "pnpm generate:openapi && orval",
    "typecheck": "pnpm typecheck:app && pnpm typecheck:node",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "verify:fast": "pnpm check && pnpm typecheck && pnpm test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@hono/node-server": "^2.0.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.28",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.555.0",
    "posthog-js": "^1.399.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/router-plugin": "^1.168.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "orval": "^8.20.0",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
