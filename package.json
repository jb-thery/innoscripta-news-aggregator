{
  "name": "signal-desk-workspace",
  "version": "1.0.0",
  "homepage": "https://jb-thery.github.io/signal-desk/",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "predev": "pnpm generate:api",
    "dev": "concurrently -k -n backend,frontend -c cyan,green \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:frontend": "pnpm --filter @signal-desk/frontend dev",
    "dev:backend": "pnpm --filter @signal-desk/backend dev",
    "prebuild": "pnpm generate:api",
    "build": "pnpm build:frontend && pnpm build:backend",
    "build:frontend": "pnpm --filter @signal-desk/frontend build",
    "build:backend": "pnpm --filter @signal-desk/backend build",
    "build:pages": "pnpm generate:api && pnpm --filter @signal-desk/frontend build:pages",
    "build:static-demo": "pnpm generate:api && pnpm --filter @signal-desk/frontend build:static-demo",
    "preview": "pnpm --filter @signal-desk/backend preview",
    "preview:static": "pnpm --filter @signal-desk/frontend preview",
    "generate:openapi": "pnpm --filter @signal-desk/backend generate:openapi",
    "generate:api": "pnpm generate:openapi && pnpm --filter @signal-desk/frontend generate:api",
    "typecheck": "pnpm typecheck:root && pnpm typecheck:workspaces",
    "typecheck:root": "tsc --noEmit -p tsconfig.tools.json",
    "typecheck:workspaces": "pnpm --filter @signal-desk/contracts --filter @signal-desk/news-domain --filter @signal-desk/ui --filter @signal-desk/backend --filter @signal-desk/frontend typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "verify:fast": "pnpm check && pnpm typecheck && pnpm test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
