# Public, non-secret frontend configuration can use VITE_ prefixes.
VITE_APP_NAME=Innoscripta News Aggregator
VITE_PUBLIC_POSTHOG_HOST=/ingest
VITE_PUBLIC_POSTHOG_KEY=
VITE_ENABLE_MOCK_DATA=false

# Provider secrets must stay server-side or proxy-side.
NEWS_API_KEY=
GUARDIAN_API_KEY=
NYT_API_KEY=

# Provider base URLs, useful for proxy configuration.
NEWS_API_BASE_URL=https://newsapi.org/v2
GUARDIAN_API_BASE_URL=https://content.guardianapis.com
NYT_API_BASE_URL=https://api.nytimes.com/svc/search/v2

# Runtime server configuration.
PORT=3000
APP_PORT=3000
MOCK_FAIL_PROVIDER=
